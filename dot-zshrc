#!/bin/zsh

# Set XDG Base Directories.
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"
# Set default editor in terminal.
export EDITOR="nvim"
export VISUAL="nvim"

# Set brew formulae/cask index mirror.
export HOMEBREW_BREW_GIT_REMOTE="https://mirror.nju.edu.cn/git/homebrew/brew.git"
export HOMEBREW_CORE_GIT_REMOTE="https://mirror.nju.edu.cn/git/homebrew/homebrew-core.git"
# Set brew bottle metadata/content mirror.
export HOMEBREW_API_DOMAIN="https://mirror.nju.edu.cn/homebrew-bottles/api"
export HOMEBREW_BOTTLE_DOMAIN="https://mirror.nju.edu.cn/homebrew-bottles"
# Set the default pip index url used by brew.
export HOMEBREW_PIP_INDEX_URL="https://mirror.nju.edu.cn/pypi/web/simple"
# Set the default brew bundle file.
export HOMEBREW_BUNDLE_FILE="$HOME/.brewrc"

# Setup shell intregration for brew.
[[ -x "/opt/homebrew/bin/brew" ]] && eval "$(/opt/homebrew/bin/brew shellenv)"

# Source plugin scripts, setup every program.
for plugin in "$XDG_CONFIG_HOME/zsh/plugins"/*.zsh; do
	source "$plugin"
done
